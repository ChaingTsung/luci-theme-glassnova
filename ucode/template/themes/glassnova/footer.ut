    </main>
    {% if (!blank_page): %}
    <footer class="gn-footer">
      Powered by <a href="https://github.com/openwrt/luci">{{ version.luciname }} ({{ version.luciversion }})</a>
      / {{ version.distname }} {{ version.distversion }} ({{ version.distrevision }})
      {% if (lua_active): %} / {{ _('Lua compatibility mode active') }}{% endif %}
    </footer>
    {% endif %}
  </div>
</body>
</html>
